# Required for real AI answers. Keep the real key in Coolify environment variables.
OPENAI_API_KEY=

# Optional. Defaults to gpt-4.1-mini in code.
OPENAI_MODEL=gpt-4.1-mini

# Leave empty for metsatark.laboratoor1um.eu.
# Only use /metsatark when deploying under a subfolder like laboratoor1um.eu/metsatark.
METSATARK_BASE_PATH=
NEXT_PUBLIC_METSATARK_BASE_PATH=
